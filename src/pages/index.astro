---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

// Ambil semua catatan dan urutkan dari yang terbaru
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.log-container {
				margin-top: 2rem;
			}
			.log-card {
				padding: 1.5rem;
				border: 1px solid #e5e7eb;
				border-radius: 12px;
				margin-bottom: 1.5rem;
				transition: transform 0.2s;
			}
			.log-card:hover {
				transform: translateY(-2px);
				border-color: #3b82f6;
			}
			.meta {
				font-size: 0.8rem;
				color: #6b7280;
				margin-bottom: 0.5rem;
			}
			.age-badge {
				background: #eff6ff;
				color: #1d4ed8;
				padding: 2px 8px;
				border-radius: 99px;
				font-weight: bold;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>🚀 Thio's Activity Log</h1>
			<p>Catatan otomatis setiap jam 17:00 WITA untuk nge-track progres belajar.</p>

			<section class="log-container">
				{
					posts.map((post) => (
						<div class="log-card">
							<div class="meta">
								<time datetime={post.data.date.toISOString()}>
									{post.data.date.toLocaleDateString('id-ID', {
										day: 'numeric',
										month: 'long',
										year: 'numeric',
									})}
								</time> 
								• <span>{post.data.timestamp} WITA</span>
							</div>
							<h3 style="margin: 0.5rem 0;">
								<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
							</h3>
							<p style="font-size: 0.9rem; color: #4b5563;">
								Status: <span class="age-badge">⏳ {post.data.writer_age_days}</span> 
								{post.data.mood && <span> • ✨ {post.data.mood}</span>}
							</p>
						</div>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>